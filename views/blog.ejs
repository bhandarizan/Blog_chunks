<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <img src="<%= blog.coverImageURL %>" width="700px" />
      <pre class="mt-3"><%= blog.body %></pre>
    </div>

    <div class="container mt-4">
      <img src="<%= blog.createdBy.profileImageURL %>" width="50px" /> <%=
      blog.createdBy.fullName %>
    </div>

    <div class="container mt-3">
      <h4>Comments (<%= comments.length %>)</h4>
      <% if (locals.user) { %>
      <form action="/blog/comment/<%= blog._id %>" method="post">
        <div class="mb-3">
          <input
            id="comment-content"
            type="text"
            name="content"
            class="form-control"
            placeholder="Enter your comment"
            required
          />
          <div class="mt-2">
            <button id="comment-add-btn" class="btn btn-sm btn-primary" type="submit" style="display:none;">Add comment</button>
          </div>
        </div>
      </form>

      <% } %>
      <div class="mt-4">
        <% comments.forEach(comment => { %>
        <div class="card mb-3 border-0">
          <div class="card-body bg-light rounded d-flex gap-3 align-items-start">
            <img src="<%= comment.createdBy.profileImageURL %>" width="50" class="rounded-circle" />
            <div>
              <div class="d-flex justify-content-between align-items-start">
                <h6 class="mb-1"><%= comment.createdBy.fullName %></h6>
              </div>
              <small class="text-muted d-block mb-2">
                <time class="comment-time" datetime="<%= new Date(comment.createdAt).toISOString() %>"><%= new Date(comment.createdAt).toLocaleString() %></time>
              </small>
              <pre class="mb-1"><%= comment.content %></pre>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <%- include('./partials/script') %>
  </body>
</html>
